# Copy to .env.local for local testing.
# Never commit real tokens.

GROQ_API_KEY=

# Discord Ask (primary chat channel — see DISCORD_SETUP.md)
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
# Optional: comma-separated guild IDs (empty = allow all)
DISCORD_ALLOWED_GUILD_IDS=

# Meta WhatsApp Cloud API (optional / legacy)
WHATSAPP_VERIFY_TOKEN=newsdash-verify-change-me
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WABA_ID=
